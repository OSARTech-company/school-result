# Security Settings (for local development only)
ALLOW_INSECURE_DEFAULTS=true
SECRET_KEY=dev-secret-key-change-me-insecure-dev-only-32chars

# Database Configuration
DATABASE_URL=postgresql://postgres:123456789@localhost:5432/schoolreultdb

# Super Admin Configuration
SUPER_ADMIN_USERNAME=osartech3@gmail.com
SUPER_ADMIN_PASSWORD=osartech2026
DEFAULT_STUDENT_PASSWORD=password
DEFAULT_TEACHER_PASSWORD=teacherpassword
BACKUP_SIGNING_KEY=your-backup-signing-key-for-just-in-case-backups-are-needed
ALLOW_RUNTIME_SCHEMA_HEAL= False

# Application Settings
FLASK_DEBUG=1
ENFORCE_PRODUCTION_ENV=1
RUN_STARTUP_BOOTSTRAP=false
RESET_STUDENT_PASSWORDS_ON_STARTUP=false
RUN_STARTUP_DDL=false
DB_POOL_MIN_CONN=3
DB_POOL_MAX_CONN=20

# Security Policy Controls
SESSION_TIMEOUT_MINUTES=120
ADMIN_PASSWORD_MAX_AGE_DAYS=90
ADMIN_2FA_CODE=123456
ADMIN_OTP_MODE=email
ADMIN_OTP_EXPIRY_MINUTES=10

# SMTP (required for email OTP delivery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=osartech3@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=osartech3@gmail.com
SUPER_ADMIN_OTP_EMAIL=osartech3@gmail.com


